CharBuffer charBuffer =

CharsetHelper.decode(buffer);

String msg = charBuffer.toString();

System.out.println("收到" +

channel.getRemoteAddress() + "的消息：" + msg);

channel.write(CharsetHelper.encode(CharBuffer.wrap(msg)));

} else {

channel.close();

}

}

} catch (Exception e) {

e.printStackTrace();

if (channel != null) {

channel.close();

}

}

}

}

